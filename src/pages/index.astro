---
import Base from "../layouts/Base.astro";
import DeescalationLine from "../components/DeescalationLine.astro";
import Picto from "../components/Picto.astro";
import { href } from "../lib/url";
import { accueil, commun } from "../lib/contenu";
import { enrichir } from "../lib/texte";
import { formationsTriees } from "../lib/formations";

const formations = await formationsTriees();
const featured = formations.slice(0, 3);
---

<Base title={accueil.seo.titre} description={accueil.seo.description}>
  <!-- ============ Hero ============ -->
  <section class="relative overflow-hidden">
    <img
      src={href("/logo-400.webp")}
      alt=""
      width="420"
      height="420"
      aria-hidden="true"
      class="pointer-events-none absolute -top-24 -right-28 h-105 w-105 opacity-[0.06] select-none"
    />
    <div class="mx-auto max-w-6xl px-6 pt-14 pb-8 sm:pt-20 md:pt-28 md:pb-10">
      <p class="eyebrow reveal reveal-1">{accueil.hero.surtitre}</p>
      <h1
        class="display reveal reveal-2 mt-4 max-w-3xl text-[2.6rem] text-navy-deep sm:text-5xl md:mt-5 md:text-[4.4rem]"
        set:html={enrichir(accueil.hero.titre)}
      />
      <p
        class="reveal reveal-3 mt-5 max-w-xl text-lg leading-relaxed text-ink-soft md:mt-7"
        set:html={enrichir(accueil.hero.texte)}
      />
      <div class="reveal reveal-4 mt-7 flex flex-wrap gap-4 md:mt-9">
        <a href={href("/formations")} class="btn btn-primary">
          {accueil.hero.bouton_principal}
          <span aria-hidden="true">→</span>
        </a>
        <a href={href("/approche")} class="btn btn-ghost">
          {accueil.hero.bouton_secondaire}
        </a>
      </div>
    </div>
    <div class="mx-auto max-w-6xl px-6">
      <DeescalationLine class="h-12 sm:h-16 md:h-24" />
    </div>
  </section>

  <!-- ============ Bande crédibilité ============ -->
  <section class="border-y border-ink/10 bg-paper-deep/60">
    <div
      class="mx-auto grid max-w-6xl grid-cols-2 gap-x-6 gap-y-8 px-6 py-10 md:grid-cols-4"
      data-reveal-group
    >
      {
        accueil.chiffres.map((c) => (
          <div class="flex flex-col gap-1" data-reveal>
            <span class="display text-2xl text-navy-deep md:text-[1.7rem]">
              {c.valeur}
            </span>
            <span class="sous-reveal text-sm leading-snug text-ink-soft">
              {c.texte}
            </span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ============ Publics ============ -->
  <section
    class="mx-auto max-w-6xl px-6 py-20"
    data-reveal-group
    data-reveal-stagger="50"
  >
    <div class="grid gap-12 md:grid-cols-[45fr_55fr] md:gap-16">
      <div>
        <p class="eyebrow" data-reveal>{accueil.publics.surtitre}</p>
        <h2
          class="display mt-4 max-w-2xl text-3xl text-navy-deep md:text-4xl"
          data-reveal
        >
          {accueil.publics.titre}
        </h2>
        <p
          class="mt-5 max-w-xl text-ink-soft"
          data-reveal
          set:html={enrichir(accueil.publics.texte)}
        />
      </div>
      <ul class="grid grid-cols-2 content-center gap-x-8 gap-y-7">
        {
          accueil.publics.liste.map((p) => (
            <li
              class="min-h-22 rounded-[4px] border-t border-ink/15 pt-4"
              data-reveal
            >
              <Picto nom={p.picto} />
              <span class="mt-2.5 block text-[0.95rem] leading-snug font-medium text-navy-deep">
                {p.label}
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============ Méthode : 4 piliers ============ -->
  <section class="bg-navy-deep text-paper">
    <div class="mx-auto max-w-6xl px-6 py-20 md:py-24">
      <p class="eyebrow !text-sage" data-reveal>{accueil.methode.surtitre}</p>
      <h2 class="display mt-4 max-w-2xl text-3xl md:text-4xl" data-reveal>
        {accueil.methode.titre}
      </h2>
      <div class="mt-14 grid gap-x-12 gap-y-12 sm:grid-cols-2" data-reveal-group>
        {
          accueil.methode.piliers.map((p) => (
            <div class="group border-t border-paper/15 pt-6" data-reveal>
              <div class="flex items-start justify-between gap-4">
                <h3 class="display text-2xl">{p.titre}</h3>
                <span class="display text-6xl leading-[0.85] text-sage/25 transition-colors duration-300 group-hover:text-sage/50">
                  {p.numero}
                </span>
              </div>
              <p class="mt-3 max-w-md text-[0.95rem] leading-relaxed text-paper/70">
                {p.texte}
              </p>
            </div>
          ))
        }
      </div>
      <p
        class="mt-14 border-l-2 border-sage pl-5 text-lg leading-relaxed text-paper/90 md:max-w-2xl"
        data-reveal
        set:html={enrichir(accueil.methode.citation, "text-sage")}
      />
    </div>
  </section>

  <!-- ============ Formations en avant ============ -->
  <section class="mx-auto max-w-6xl px-6 py-20 md:py-24">
    <div class="flex flex-wrap items-end justify-between gap-6" data-reveal>
      <div>
        <p class="eyebrow">{accueil.formations.surtitre}</p>
        <h2 class="display mt-4 text-3xl text-navy-deep md:text-4xl">
          {accueil.formations.titre}
        </h2>
      </div>
      <a href={href("/formations")} class="btn btn-ghost">
        {accueil.formations.bouton_tous} <span aria-hidden="true">→</span>
      </a>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-3" data-reveal-group>
      {
        featured.map((f) => (
          <a
            href={href(`/formations/${f.id}`)}
            class="card group flex flex-col p-7"
            data-reveal
          >
            <h3 class="display text-xl leading-snug text-navy-deep">
              {f.data.titre}
            </h3>
            <p class="mt-3 flex-1 text-[0.95rem] leading-relaxed text-ink-soft">
              {f.data.accroche}
            </p>
            <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-sage-deep">
              {accueil.formations.lien_programme}
              <span
                aria-hidden="true"
                class="transition-transform duration-200 group-hover:translate-x-1"
              >
                →
              </span>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ============ À propos teaser ============ -->
  <section class="border-y border-ink/10 bg-paper-deep/60">
    <div
      class="mx-auto grid max-w-6xl items-center gap-10 px-6 py-20 md:grid-cols-[auto_1fr] md:gap-16"
      data-reveal-group
    >
      <div
        class="relative mx-auto w-60 md:w-80"
        data-portrait
        data-portrait-directional
        data-reveal
      >
        <span class="portrait-cadre" aria-hidden="true"></span>
        <span class="portrait-direction" aria-hidden="true"></span>
        <img
          src={href("/fabien.webp")}
          alt={commun.photos.portrait_alt}
          width="640"
          height="800"
          class="relative aspect-4/5 w-full rounded-[6px] object-cover object-[50%_30%]"
        />
      </div>
      <div data-portrait-copy data-reveal>
        <p class="portrait-copy-step portrait-copy-kicker eyebrow">
          {accueil.formateur.surtitre}
        </p>
        <h2
          class="portrait-copy-step portrait-copy-title display mt-4 max-w-2xl text-3xl text-navy-deep md:text-4xl"
        >
          {accueil.formateur.titre}
        </h2>
        <p
          class="portrait-copy-step portrait-copy-body mt-5 max-w-2xl leading-relaxed text-ink-soft"
          set:html={enrichir(accueil.formateur.texte)}
        />
        <a
          href={href("/a-propos")}
          class="portrait-copy-step portrait-copy-action btn btn-ghost mt-8"
        >
          {accueil.formateur.bouton}
        </a>
      </div>
    </div>
  </section>

  <!-- ============ CTA final ============ -->
  <section class="mx-auto max-w-6xl px-6 py-24 text-center" data-reveal-group>
    <h2
      class="display mx-auto max-w-2xl text-4xl text-navy-deep md:text-5xl"
      data-reveal
    >
      {accueil.appel_final.titre}
    </h2>
    <p
      class="mx-auto mt-5 max-w-xl text-ink-soft"
      data-reveal
      set:html={enrichir(accueil.appel_final.texte)}
    />
    <a href={href("/contact")} class="btn btn-primary mt-9" data-reveal>
      {accueil.appel_final.bouton} <span aria-hidden="true">→</span>
    </a>
  </section>
</Base>
