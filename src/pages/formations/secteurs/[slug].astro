---
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";
import { href } from "../../../lib/url";
import { formationsPage } from "../../../lib/contenu";
import { enrichir } from "../../../lib/texte";

export async function getStaticPaths() {
  const secteurs = await getCollection("secteurs");
  return secteurs.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { seo, entete, enjeux, programmes, paxi_en_avant, cta } = entry.data;
const { carte } = formationsPage;

const toutes = await getCollection("formations");
const selection = programmes
  .map((slug) => toutes.find((f) => f.id === slug))
  .filter((f) => f !== undefined);
---

<Base
  title={seo.titre}
  description={seo.description}
  fil={[
    { label: "Formations", chemin: "/formations" },
    { label: entry.data.nom, chemin: `/formations/secteurs/${entry.id}` },
  ]}
>
  <section class="mx-auto max-w-6xl px-6 pt-16 pb-20 md:pt-24">
    <a
      href={href("/formations")}
      class="inline-flex items-center gap-2 text-sm font-semibold text-sage-deep hover:text-navy-deep"
    >
      <span aria-hidden="true">←</span> Toutes les formations
    </a>

    <p class="eyebrow mt-8">{entete.surtitre}</p>
    <h1 class="display mt-4 max-w-3xl text-4xl text-navy-deep md:text-5xl">
      {entete.titre}
    </h1>
    <p
      class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-soft"
      data-mots
      set:html={enrichir(entete.texte)}
    />

    {
      enjeux.length > 0 && (
        <div class="mt-14 grid gap-8 md:grid-cols-3" data-reveal-group>
          {enjeux.map((e) => (
            <div class="border-t border-ink/15 pt-5" data-reveal>
              <h2 class="display text-xl text-navy-deep">{e.titre}</h2>
              <p class="mt-3 text-[0.95rem] leading-relaxed text-ink-soft">
                {e.texte}
              </p>
            </div>
          ))}
        </div>
      )
    }

    {
      paxi_en_avant && (
        <a
          href={href("/formations/paxi")}
          class="group mt-14 flex flex-col gap-4 rounded-2xl bg-abysse p-8 text-paper shadow-(--shadow-card) transition-transform duration-300 hover:-translate-y-0.5 md:flex-row md:items-center md:justify-between"
          data-reveal
        >
          <div>
            <p class="eyebrow !text-sage">Produit phare</p>
            <h2 class="display mt-2 text-2xl">
              PAXI — gestion des passagers indisciplinés
            </h2>
            <p class="mt-2 max-w-2xl text-[0.95rem] leading-relaxed text-paper/75">
              Le module complet, déployé en CQP PNC : classification des
              risques, cadre légal, désescalade et coordination d'équipage.
            </p>
          </div>
          <span class="btn shrink-0 self-start border-1.5 border-sage bg-sage !px-6 text-abysse group-hover:border-paper group-hover:bg-paper md:self-center">
            Découvrir le PAXI <span aria-hidden="true">→</span>
          </span>
        </a>
      )
    }

    {
      selection.length > 0 && (
        <div class="mt-16" data-reveal-group>
          <h2 class="display text-2xl text-navy-deep md:text-3xl" data-reveal>
            Les programmes recommandés
          </h2>
          <div class="mt-8 grid gap-6 md:grid-cols-2">
            {selection.map((f) => (
              <a
                href={href(`/formations/${f.id}`)}
                class="card group flex flex-col p-7"
                data-reveal
              >
                <h3 class="display text-xl leading-snug text-navy-deep">
                  {f.data.titre}
                </h3>
                <p class="mt-3 flex-1 text-[0.95rem] leading-relaxed text-ink-soft">
                  {f.data.accroche}
                </p>
                <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-sage-deep">
                  {carte.lien_programme}
                  <span
                    aria-hidden="true"
                    class="transition-transform duration-200 group-hover:translate-x-1"
                  >
                    →
                  </span>
                </span>
              </a>
            ))}
          </div>
        </div>
      )
    }

    <div class="mt-20 rounded-2xl border border-ink/10 bg-paper-deep/40 p-10 text-center">
      <h2 class="display mx-auto max-w-xl text-2xl text-navy-deep md:text-3xl">
        {cta.titre}
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-ink-soft">{cta.texte}</p>
      <a href={href("/contact")} class="btn btn-primary mt-7">
        Prendre contact <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</Base>
