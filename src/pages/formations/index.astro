---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Picto from "../../components/Picto.astro";
import { href } from "../../lib/url";
import { formationsPage } from "../../lib/contenu";
import { enrichir } from "../../lib/texte";
import { formationsTriees } from "../../lib/formations";

const formations = await formationsTriees();
const secteurs = (await getCollection("secteurs")).sort(
  (a, b) => a.data.ordre - b.data.ordre,
);
const { seo, entete, portes, paxi_banniere, carte } = formationsPage;

const pictosSecteurs: Record<string, string> = {
  entreprise: "building-2",
  collectivite: "landmark",
  "organisme-aeronautique": "plane",
  "organisme-securite-privee": "shield-check",
};
---

<Base
  title={seo.titre}
  description={seo.description}
  typePage="CollectionPage"
  fil={[{ label: entete.surtitre, chemin: "/formations" }]}
>
  <section class="mx-auto max-w-6xl px-6 pt-16 pb-20 md:pt-24">
    <p class="eyebrow">{entete.surtitre}</p>
    <h1 class="display mt-4 max-w-3xl text-4xl text-navy-deep md:text-5xl">
      {entete.titre}
    </h1>
    <p
      class="mt-6 max-w-2xl leading-relaxed text-ink-soft"
      set:html={enrichir(entete.texte)}
    />

    <!-- Bannière produit phare PAXI -->
    <a
      href={href("/formations/paxi")}
      class="group mt-12 flex flex-col gap-4 rounded-2xl bg-abysse p-8 text-paper shadow-(--shadow-card) transition-transform duration-300 hover:-translate-y-0.5 md:flex-row md:items-center md:justify-between"
      data-reveal
    >
      <div>
        <p class="eyebrow !text-sage">{paxi_banniere.surtitre}</p>
        <h2 class="display mt-2 text-2xl">{paxi_banniere.titre}</h2>
        <p class="mt-2 max-w-2xl text-[0.95rem] leading-relaxed text-paper/75">
          {paxi_banniere.texte}
        </p>
      </div>
      <span
        class="btn shrink-0 self-start border-1.5 border-sage bg-sage !px-6 text-abysse group-hover:border-paper group-hover:bg-paper md:self-center"
      >
        {paxi_banniere.bouton}
        <span aria-hidden="true">→</span>
      </span>
    </a>

    <!-- Porte 1 : par secteur -->
    <div class="mt-16" data-reveal-group data-reveal-stagger="50">
      <h2 class="display text-2xl text-navy-deep md:text-3xl" data-reveal>
        {portes.secteur.titre}
      </h2>
      <p class="mt-2 max-w-xl text-ink-soft" data-reveal>
        {portes.secteur.texte}
      </p>
      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          secteurs.map((s) => (
            <a
              href={href(`/formations/secteurs/${s.id}`)}
              class="card flex flex-col p-6"
              data-reveal
            >
              <Picto nom={pictosSecteurs[s.id] ?? "users-round"} />
              <h3 class="display mt-3 text-lg leading-snug text-navy-deep">
                {s.data.nom}
              </h3>
              {s.data.statut === "stub" && (
                <span class="mt-2 inline-block self-start rounded-full bg-paper-deep/60 px-3 py-1 text-[0.68rem] font-semibold tracking-wide text-ink-faint uppercase">
                  {carte.badge_stub}
                </span>
              )}
              <span class="mt-auto inline-flex items-center gap-2 pt-4 text-sm font-semibold text-sage-deep">
                {carte.lien_secteur}
                <span aria-hidden="true">→</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>

    <!-- Porte 2 : par besoin -->
    <div class="mt-16" data-reveal-group>
      <h2 class="display text-2xl text-navy-deep md:text-3xl" data-reveal>
        {portes.besoin.titre}
      </h2>
      <p class="mt-2 max-w-xl text-ink-soft" data-reveal>
        {portes.besoin.texte}
      </p>
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        {
          formations.map((f) => (
            <a
              href={href(`/formations/${f.id}`)}
              class="card group flex flex-col p-8"
              data-reveal
            >
              <h3 class="display text-[1.45rem] leading-snug text-navy-deep">
                {f.data.titre}
              </h3>
              <p class="mt-3 flex-1 leading-relaxed text-ink-soft">
                {f.data.accroche}
              </p>
              <ul class="mt-6 flex flex-wrap gap-2">
                {f.data.publics.map((p) => (
                  <li class="rounded-full bg-sage-faint px-3.5 py-1.5 text-xs font-semibold text-sage-deep">
                    {p}
                  </li>
                ))}
              </ul>
              <div class="mt-6 flex items-center justify-between border-t border-ink/10 pt-5 text-sm">
                <span class="text-ink-faint">
                  {f.data.duree} · {f.data.format}
                </span>
                <span class="inline-flex items-center gap-2 font-semibold text-sage-deep">
                  {carte.lien_programme}
                  <span
                    aria-hidden="true"
                    class="transition-transform duration-200 group-hover:translate-x-1"
                  >
                    →
                  </span>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Base>
