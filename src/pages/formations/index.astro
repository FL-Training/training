---
import Base from "../../layouts/Base.astro";
import { href } from "../../lib/url";
import { formationsPage } from "../../lib/contenu";
import { enrichir } from "../../lib/texte";
import { formationsTriees } from "../../lib/formations";

const formations = await formationsTriees();
const { seo, entete, carte } = formationsPage;
---

<Base title={seo.titre} description={seo.description}>
  <section class="mx-auto max-w-6xl px-6 pt-16 pb-20 md:pt-24">
    <p class="eyebrow">{entete.surtitre}</p>
    <h1 class="display mt-4 max-w-3xl text-4xl text-navy-deep md:text-5xl">
      {entete.titre}
    </h1>
    <p
      class="mt-6 max-w-2xl leading-relaxed text-ink-soft"
      set:html={enrichir(entete.texte)}
    />

    <div class="mt-14 grid gap-6 md:grid-cols-2" data-reveal-group>
      {
        formations.map((f) => (
          <a
            href={href(`/formations/${f.id}`)}
            class="card group flex flex-col p-8"
            data-reveal
          >
            <h2 class="display text-[1.45rem] leading-snug text-navy-deep">
              {f.data.titre}
            </h2>
            <p class="mt-3 flex-1 leading-relaxed text-ink-soft">
              {f.data.accroche}
            </p>
            <ul class="mt-6 flex flex-wrap gap-2">
              {f.data.publics.map((p) => (
                <li class="rounded-full bg-sage-faint px-3.5 py-1.5 text-xs font-semibold text-sage-deep">
                  {p}
                </li>
              ))}
            </ul>
            <div class="mt-6 flex items-center justify-between border-t border-ink/10 pt-5 text-sm">
              <span class="text-ink-faint">
                {f.data.duree} · {f.data.format}
              </span>
              <span class="inline-flex items-center gap-2 font-semibold text-sage-deep">
                {carte.lien_programme}
                <span
                  aria-hidden="true"
                  class="transition-transform duration-200 group-hover:translate-x-1"
                >
                  →
                </span>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Base>
