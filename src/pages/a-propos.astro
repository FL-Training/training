---
import Base from "../layouts/Base.astro";
import { href } from "../lib/url";
import { aPropos, commun } from "../lib/contenu";
import { enrichir } from "../lib/texte";

const { seo, entete, parcours, ton } = aPropos;
---

<Base
  title={seo.titre}
  description={seo.description}
  typePage="AboutPage"
  fil={[{ label: "À propos", chemin: "/a-propos" }]}
>
  <section class="mx-auto max-w-6xl px-6 pt-16 md:pt-24">
    <div class="grid items-start gap-10 md:grid-cols-[1fr_auto]" data-reveal-group>
      <div data-reveal>
        <p class="eyebrow">{entete.surtitre}</p>
        <h1 class="display mt-4 max-w-2xl text-4xl text-navy-deep md:text-5xl">
          {entete.titre}
        </h1>
        <p
          class="mt-6 max-w-2xl text-lg leading-relaxed text-ink"
          data-mots
          set:html={enrichir(entete.texte)}
        />
      </div>
      <div
        class="relative mx-auto w-60 md:mx-0 md:w-72"
        data-portrait
        data-reveal
      >
        <span class="portrait-cadre" aria-hidden="true"></span>
        <img
          src={href("/fabien.webp")}
          alt={commun.photos.portrait_alt}
          width="640"
          height="800"
          class="relative aspect-4/5 w-full rounded-[6px] object-cover object-[50%_30%]"
        />
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16">
    <ol
      class="timeline relative space-y-12 pl-8 md:pl-12"
      data-timeline
      data-reveal
      data-reveal-group
    >
      {
        parcours.map((etape) => (
          <li class="timeline-item relative" data-reveal>
            <span
              class="timeline-node absolute -left-[2.375rem] top-2 h-3 w-3 rounded-full border-2 border-sage-deep bg-paper md:-left-[3.375rem]"
              aria-hidden="true"
            />
            <p class="eyebrow">{etape.periode}</p>
            <h2 class="display mt-2 text-2xl text-navy-deep">{etape.titre}</h2>
            <p
              class="mt-3 max-w-2xl leading-relaxed text-ink-soft"
              set:html={enrichir(etape.texte)}
            />
          </li>
        ))
      }
    </ol>
  </section>

  <section class="border-y border-ink/10 bg-paper-deep/60">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <h2 class="display max-w-2xl text-3xl text-navy-deep">{ton.titre}</h2>
      <p
        class="mt-5 max-w-2xl leading-relaxed text-ink-soft"
        set:html={enrichir(ton.texte)}
      />
      <div class="mt-8 flex flex-wrap gap-4">
        <a href={href("/contact")} class="btn btn-primary">
          {ton.bouton_contact}
        </a>
        <a
          href={commun.liens.linkedin}
          rel="noopener noreferrer"
          target="_blank"
          class="btn btn-ghost"
        >
          {ton.bouton_linkedin}
        </a>
      </div>
    </div>
  </section>
</Base>
