---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import { href } from "../../lib/url";
import { racineSite, urlAbsolue } from "../../lib/seo";

export async function getStaticPaths() {
  const articles = await getCollection("journal");
  return articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const nomsFlux: Record<string, string> = {
  "revue-litteraire": "Revue littéraire",
  "point-de-vue-actu": "Point de vue actu",
  "terrain-et-pratiques": "Terrain & pratiques",
  "methodes-et-reperes": "Méthodes & repères",
};

const formatDate = new Intl.DateTimeFormat("fr-FR", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const racine = racineSite(Astro.site!, import.meta.env.BASE_URL);
const noeudsSeo = [
  {
    "@type": "Article",
    "@id": `${new URL(Astro.url.pathname, Astro.site).href}#article`,
    headline: entry.data.titre,
    description: entry.data.resume,
    datePublished: entry.data.date.toISOString().slice(0, 10),
    author: { "@id": `${racine}#fabien-lacombe` },
    publisher: { "@id": `${racine}#organization` },
    mainEntityOfPage: urlAbsolue(Astro.site!, Astro.url.pathname),
    articleSection: nomsFlux[entry.data.flux],
    inLanguage: "fr-FR",
  },
];
---

<Base
  title={entry.data.titre}
  description={entry.data.resume}
  fil={[
    { label: "Le Journal", chemin: "/journal" },
    { label: entry.data.titre, chemin: `/journal/${entry.id}` },
  ]}
  noeudsSeo={noeudsSeo}
>
  <article class="mx-auto max-w-3xl px-6 pt-14 pb-20 md:pt-20">
    <a
      href={href("/journal")}
      class="inline-flex items-center gap-2 text-sm font-semibold text-sage-deep hover:text-navy-deep"
    >
      <span aria-hidden="true">←</span> Le Journal
    </a>

    <div class="mt-8 flex flex-wrap items-center gap-3 text-xs">
      <span
        class="rounded-full bg-sage-faint px-3 py-1 font-semibold text-sage-deep"
      >
        {nomsFlux[entry.data.flux]}
      </span>
      <time
        datetime={entry.data.date.toISOString().slice(0, 10)}
        class="text-ink-faint"
      >
        {formatDate.format(entry.data.date)}
      </time>
      <span class="text-ink-faint">· {entry.data.auteur}</span>
    </div>

    <h1 class="display mt-4 text-3xl text-navy-deep md:text-[2.8rem]">
      {entry.data.titre}
    </h1>
    <p class="mt-5 text-lg leading-relaxed text-ink-soft">
      {entry.data.resume}
    </p>

    <div class="prose-site mt-10">
      <Content />
    </div>

    {
      entry.data.sources.length > 0 && (
        <aside class="mt-12 border-t border-ink/10 pt-6">
          <h2 class="eyebrow">Sources</h2>
          <ul class="mt-3 space-y-1.5 text-sm">
            {entry.data.sources.map((s) => (
              <li>
                <a
                  href={s.url}
                  rel="noopener noreferrer"
                  target="_blank"
                  class="font-medium text-sage-deep underline decoration-sage/40 underline-offset-2 hover:text-navy-deep"
                >
                  {s.titre}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }

    <div
      class="mt-14 rounded-2xl border border-ink/10 bg-paper-deep/40 p-8 text-center"
    >
      <p class="display text-xl text-navy-deep">
        Ces repères s'entraînent en formation.
      </p>
      <div class="mt-5 flex flex-wrap justify-center gap-3">
        <a href={href("/formations")} class="btn btn-primary !px-6 !py-2.5 text-sm">
          Voir les formations
        </a>
        <a href={href("/approche")} class="btn btn-ghost !px-6 !py-2.5 text-sm">
          Notre approche
        </a>
      </div>
    </div>
  </article>
</Base>
