---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { href } from "../../lib/url";

const articles = (await getCollection("journal")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const nomsFlux: Record<string, string> = {
  "revue-litteraire": "Revue littéraire",
  "point-de-vue-actu": "Point de vue actu",
  "terrain-et-pratiques": "Terrain & pratiques",
  "methodes-et-reperes": "Méthodes & repères",
};
const fluxPresents = [...new Set(articles.map((a) => a.data.flux))];

const formatDate = new Intl.DateTimeFormat("fr-FR", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Base
  title="Le Journal Pacivis"
  description="Articles de fond sur la prévention et la gestion des conflits : méthodes, repères, terrain et points de vue — par Fabien Lacombe."
  typePage="CollectionPage"
  fil={[{ label: "Le Journal", chemin: "/journal" }]}
>
  <section class="mx-auto max-w-6xl px-6 pt-16 pb-20 md:pt-24">
    <p class="eyebrow">Le Journal Pacivis</p>
    <h1 class="display mt-4 max-w-3xl text-4xl text-navy-deep md:text-5xl">
      Comprendre avant d'agir.
    </h1>
    <p class="mt-6 max-w-2xl leading-relaxed text-ink-soft">
      Méthodes, repères, retours de terrain et points de vue : des articles de
      fond pour celles et ceux qui font face au conflit dans leur métier.
    </p>

    <!-- Filtres par flux -->
    <div class="mt-10 flex flex-wrap gap-2" id="filtres-journal">
      <button
        type="button"
        data-filtre="tous"
        class="filtre-flux filtre-actif rounded-full border border-ink/15 px-4 py-2 text-sm font-medium"
      >
        Tous
      </button>
      {
        fluxPresents.map((flux) => (
          <button
            type="button"
            data-filtre={flux}
            class="filtre-flux rounded-full border border-ink/15 px-4 py-2 text-sm font-medium"
          >
            {nomsFlux[flux]}
          </button>
        ))
      }
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2" data-reveal-group>
      {
        articles.map((article) => (
          <a
            href={href(`/journal/${article.id}`)}
            class="card group flex flex-col p-8"
            data-flux={article.data.flux}
            data-reveal
          >
            <div class="flex items-center gap-3 text-xs">
              <span class="rounded-full bg-sage-faint px-3 py-1 font-semibold text-sage-deep">
                {nomsFlux[article.data.flux]}
              </span>
              <time
                datetime={article.data.date.toISOString().slice(0, 10)}
                class="text-ink-faint"
              >
                {formatDate.format(article.data.date)}
              </time>
            </div>
            <h2 class="display mt-4 text-[1.35rem] leading-snug text-navy-deep">
              {article.data.titre}
            </h2>
            <p class="mt-3 flex-1 text-[0.95rem] leading-relaxed text-ink-soft">
              {article.data.resume}
            </p>
            <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-sage-deep">
              Lire l'article
              <span
                aria-hidden="true"
                class="transition-transform duration-200 group-hover:translate-x-1"
              >
                →
              </span>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <script>
    function initFiltres() {
      const boutons = document.querySelectorAll<HTMLButtonElement>(".filtre-flux");
      const cartes = document.querySelectorAll<HTMLElement>("[data-flux]");
      boutons.forEach((bouton) => {
        bouton.addEventListener("click", () => {
          boutons.forEach((b) => b.classList.remove("filtre-actif"));
          bouton.classList.add("filtre-actif");
          const filtre = bouton.dataset.filtre;
          cartes.forEach((carte) => {
            carte.style.display =
              filtre === "tous" || carte.dataset.flux === filtre ? "" : "none";
          });
        });
      });
    }
    document.addEventListener("astro:page-load", initFiltres);
  </script>
</Base>
