---
import Base from "../layouts/Base.astro";
import DeescalationLine from "../components/DeescalationLine.astro";
import { href } from "../lib/url";
import { approche } from "../lib/contenu";
import { enrichir } from "../lib/texte";

const { seo, entete, piliers, cadre, appel_final } = approche;
---

<Base title={seo.titre} description={seo.description}>
  <section class="mx-auto max-w-6xl px-6 pt-16 md:pt-24">
    <p class="eyebrow">{entete.surtitre}</p>
    <h1 class="display mt-4 max-w-3xl text-4xl text-navy-deep md:text-5xl">
      {entete.titre}
    </h1>
    <p
      class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-soft"
      set:html={enrichir(entete.texte)}
    />
    <DeescalationLine class="mt-12 h-14 md:h-20" />
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16">
    <ol class="space-y-14" data-reveal-group>
      {
        piliers.map((p) => (
          <li
            class="grid gap-5 border-t border-ink/10 pt-8 md:grid-cols-[110px_1fr] md:gap-10"
            data-reveal
          >
            <span class="display text-5xl text-sage/60 md:text-6xl">
              {p.numero}
            </span>
            <div>
              <h2 class="display max-w-xl text-2xl text-navy-deep">
                {p.titre}
              </h2>
              <p
                class="mt-4 max-w-2xl leading-relaxed text-ink-soft"
                set:html={enrichir(p.texte)}
              />
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="bg-navy-deep text-paper">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="eyebrow !text-sage">{cadre.surtitre}</p>
      <h2 class="display mt-4 max-w-2xl text-3xl md:text-4xl">
        {cadre.titre}
      </h2>
      <div class="mt-10 grid gap-8 md:grid-cols-3" data-reveal-group>
        {
          cadre.points.map((point) => (
            <div class="border-t border-paper/15 pt-5" data-reveal>
              <h3 class="display text-xl">{point.titre}</h3>
              <p
                class="mt-3 text-[0.95rem] leading-relaxed text-paper/70"
                set:html={enrichir(point.texte, "text-sage")}
              />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-20 text-center">
    <h2 class="display mx-auto max-w-2xl text-3xl text-navy-deep md:text-4xl">
      {appel_final.titre}
    </h2>
    <p
      class="mx-auto mt-5 max-w-xl text-ink-soft"
      set:html={enrichir(appel_final.texte)}
    />
    <div class="mt-9 flex flex-wrap justify-center gap-4">
      <a href={href("/formations")} class="btn btn-primary">
        {appel_final.bouton_formations}
      </a>
      <a href={href("/contact")} class="btn btn-ghost">
        {appel_final.bouton_contact}
      </a>
    </div>
  </section>
</Base>
