---
import Base from "../layouts/Base.astro";
import WaitlistForm from "../components/react/WaitlistForm";
import Picto from "../components/Picto.astro";
import { href } from "../lib/url";
import { espaceApprenant } from "../lib/contenu";
import { enrichir } from "../lib/texte";

const { lance, url_skool, seo, entete, contenu, statut, formulaire, note_pro } =
  espaceApprenant;

const pictosContenu = ["graduation-cap", "shield-check", "users-round"];
---

<Base
  title={seo.titre}
  description={seo.description}
  fil={[{ label: "Espace apprenant", chemin: "/espace-apprenant" }]}
>
  <section class="mx-auto max-w-6xl px-6 pt-16 pb-20 md:pt-24">
    <p class="eyebrow">{entete.surtitre}</p>
    <h1 class="display mt-4 max-w-3xl text-4xl text-navy-deep md:text-5xl">
      {entete.titre}
    </h1>
    <p
      class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-soft"
      data-mots
      set:html={enrichir(entete.texte)}
    />

    <div class="mt-14" data-reveal-group data-reveal-stagger="50">
      <h2 class="display text-2xl text-navy-deep md:text-3xl" data-reveal>
        {contenu.titre}
      </h2>
      <div class="mt-8 grid gap-8 md:grid-cols-3">
        {
          contenu.liste.map((c, i) => (
            <div class="border-t border-ink/15 pt-5" data-reveal>
              <Picto nom={pictosContenu[i] ?? "graduation-cap"} />
              <h3 class="display mt-3 text-xl text-navy-deep">{c.titre}</h3>
              <p class="mt-2 text-[0.95rem] leading-relaxed text-ink-soft">
                {c.texte}
              </p>
            </div>
          ))
        }
      </div>
    </div>

    <div
      class="mt-16 rounded-2xl bg-abysse p-8 text-paper md:p-12"
      data-reveal
    >
      {
        lance && url_skool ? (
          <div class="text-center">
            <h2 class="display text-2xl md:text-3xl">{statut.bouton_skool}</h2>
            <a
              href={url_skool}
              rel="noopener noreferrer"
              target="_blank"
              class="btn mt-6 border-1.5 border-sage bg-sage !px-8 text-abysse hover:border-paper hover:bg-paper"
            >
              {statut.bouton_skool} <span aria-hidden="true">→</span>
            </a>
          </div>
        ) : (
          <div class="mx-auto max-w-xl">
            <h2 class="display text-2xl md:text-3xl">{statut.titre}</h2>
            <p class="mt-3 leading-relaxed text-paper/80">{statut.texte}</p>
            <div class="mt-7">
              <WaitlistForm client:load textes={formulaire} />
            </div>
          </div>
        )
      }
    </div>

    <p class="mt-12 max-w-2xl text-sm leading-relaxed text-ink-faint">
      {note_pro}
      <a
        href={href("/formations")}
        class="font-semibold text-sage-deep hover:text-navy-deep"
      >
        Voir les formations professionnelles →
      </a>
    </p>
  </section>
</Base>
