---
/**
 * Signature motif: a line that starts chaotic and settles into calm —
 * de-escalation, visualized. Draws itself on page load.
 */
interface Props {
  class?: string;
  animated?: boolean;
}
const { class: className = "", animated = true } = Astro.props;
---

<svg
  class={`w-full ${className}`}
  viewBox="0 0 1200 110"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  preserveAspectRatio="none"
>
  <path
    class={animated ? "deescalation-path" : ""}
    d="M0 55
       L36 14 L72 96 L108 22 L144 88 L180 30 L216 80
       L252 38 L288 72 L324 44 L360 66 L396 48 L432 62
       C 480 52, 520 58, 560 55
       L1148 55"
    stroke="var(--color-sage-deep)"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"></path>
  <circle
    class={animated ? "deescalation-dot" : ""}
    cx="1160"
    cy="55"
    r="5"
    fill="var(--color-navy)"></circle>
</svg>
