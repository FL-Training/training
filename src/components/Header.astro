---
import { href } from "../lib/url";
import { commun } from "../lib/contenu";

const base = import.meta.env.BASE_URL.replace(/\/+$/, "");
const current = Astro.url.pathname.replace(base, "").replace(/\/+$/, "") || "/";

function isCurrent(path: string): boolean {
  if (path === "/") return current === "/";
  return current === path || current.startsWith(`${path}/`);
}
---

<header
  transition:animate="none"
  class="sticky top-0 z-40 border-b border-ink/10 bg-paper/85 backdrop-blur-md"
>
  <span class="nav-progress" aria-hidden="true"></span>
  <div
    class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-6 py-4"
  >
    <a href={href("/")} class="group flex items-center gap-3">
      <img
        src={href("/logo-96.png")}
        alt=""
        width="44"
        height="44"
        class="h-11 w-11 transition-transform duration-300 group-hover:rotate-6"
      />
      <span class="flex flex-col leading-tight">
        <span class="display text-lg text-navy-deep">{commun.marque.nom}</span>
        <span
          class="hidden text-[0.62rem] font-semibold tracking-[0.2em] text-ink-faint uppercase sm:block"
        >
          {commun.marque.slogan}
        </span>
      </span>
    </a>

    <nav class="hidden items-center gap-7 lg:flex" aria-label="Navigation principale">
      {
        commun.navigation.map((item) => (
          <a
            href={href(item.chemin)}
            class="nav-link"
            aria-current={isCurrent(item.chemin) ? "page" : undefined}
          >
            {item.label}
            {isCurrent(item.chemin) && (
              <span
                class="nav-souligne"
                transition:name="nav-actif"
                aria-hidden="true"
              />
            )}
          </a>
        ))
      }
    </nav>

    <a
      href={href("/contact")}
      class="btn btn-primary hidden !px-5 !py-2.5 text-sm lg:inline-flex"
    >
      {commun.boutonContact}
    </a>

    <details class="relative lg:hidden">
      <summary
        class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full border border-ink/15 [&::-webkit-details-marker]:hidden"
        aria-label="Ouvrir le menu"
      >
        <svg
          class="menu-icone h-5 w-5 text-ink"
          viewBox="0 0 20 20"
          fill="none"
          aria-hidden="true"
        >
          <path
            class="ligne-1"
            d="M3 5.5h14"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"></path>
          <path
            class="ligne-2"
            d="M3 10h14"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"></path>
          <path
            class="ligne-3"
            d="M3 14.5h14"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"></path>
        </svg>
      </summary>
      <nav
        class="menu-panneau absolute right-0 top-13 z-50 flex w-56 flex-col gap-1 rounded-xl border border-ink/10 bg-paper p-3 shadow-(--shadow-card-hover)"
        aria-label="Navigation mobile"
      >
        {
          commun.navigation.map((item, i) => (
            <a
              href={href(item.chemin)}
              style={`--i: ${i}`}
              class="flex min-h-11 items-center rounded-lg px-3 py-2 text-sm font-medium text-ink-soft hover:bg-paper-deep hover:text-navy-deep"
              aria-current={isCurrent(item.chemin) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </details>
  </div>
</header>
